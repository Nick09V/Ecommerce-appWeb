<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/styles.css"> 
</head>
<body>
    <div class="bg-orbs">
        <div class="orb orb--1"></div>
        <div class="orb orb--2"></div>
        <div class="orb orb--3"></div>
    </div>

    <header>
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory/detail/<%= item.id %>" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted);">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Volver al Producto
            </a>
            <form action="/auth/signout" method="POST" style="display: inline; margin: 0;">
                <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem;">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 2rem; position: relative; z-index: 1;">
        <div class="chat-wrapper">
            
            <div class="chat-container glass-panel">
                
                <div class="chat-header">
                    <img src="<%= item.image_url || 'https://via.placeholder.com/50/1e1b4b/4f46e5?text=Img' %>" alt="<%= item.title %>">
                    
                    <div class="chat-header-info">
                        <h3 style="margin: 0; font-size: 1.125rem; color: var(--text-main);"><%= item.title %></h3>
                        <div style="font-size: 0.875rem; color: var(--text-muted);">
                            Conversando con: <strong style="color: var(--accent);"><%= partner.first_name %> <%= partner.last_name %></strong>
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-dim);">
                            N° Parte: <%= item.part_number %>
                        </div>
                    </div>
                    
                    <div style="margin-left: auto; font-weight: 700; color: #86efac; font-size: 1.5rem;">
                        $<%= item.price %>
                    </div>
                </div>

                <div class="chat-messages" id="messages-container">
                    <% if (typeof history !== 'undefined' && history.length > 0) { %>
                        <% history.forEach(msg => { %>
                            <div class="message <%= msg.sender_id === user.id ? 'message-sent' : 'message-received' %>">
                                <%= msg.content %>
                                <span class="message-time">
                                    <%= new Date(msg.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                </span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; color: var(--text-dim); padding: 2rem; font-size: 0.9375rem;" id="empty-state">
                            No hay mensajes previos. ¡Inicia la conversación!
                        </div>
                    <% } %>
                </div>

                <form class="chat-input-area" id="chat-form">
                    <input type="text" id="message-input" placeholder="Escribe tu mensaje aquí..." autocomplete="off" required>
                    <button type="submit" class="btn" style="border-radius: 9999px; padding: 0.875rem 1.75rem;">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right: 0.25rem; transform: rotate(45deg); margin-top: -2px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5m0 0l-7 7m7-7l7 7"></path>
                        </svg>
                        Enviar
                    </button>
                </form>
            </div>

        </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const socket = io();
            
            const form = document.getElementById('chat-form');
            const input = document.getElementById('message-input');
            const messagesContainer = document.getElementById('messages-container');
            const emptyState = document.getElementById('empty-state');
            
            const inventoryId = parseInt("<%= item.id %>", 10);
            const receiverId = parseInt("<%= partner.id %>", 10); 
            
            const scrollToBottom = () => {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            };
            
            scrollToBottom();

            function appendMessage(text, isSent, timestamp = new Date()) {
                if (emptyState) emptyState.style.display = 'none';

                const msgDiv = document.createElement('div');
                msgDiv.classList.add('message');
                msgDiv.classList.add(isSent ? 'message-sent' : 'message-received');
                
                const timeStr = new Date(timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                msgDiv.innerHTML = `${text}<span class="message-time">${timeStr}</span>`;
                
                messagesContainer.appendChild(msgDiv);
                scrollToBottom();
            }

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const msgText = input.value.trim();
                
                if (msgText) {
                    socket.emit('chat:message', {
                        message: msgText,
                        inventoryId: inventoryId,
                        receiverId: receiverId
                    });
                    input.value = ''; 
                }
            });

            socket.on('chat:sent_success', (savedMessage) => {
                appendMessage(savedMessage.content, true, savedMessage.created_at);
            });

            socket.on('chat:receive', (incomingMessage) => {
                if (incomingMessage.inventory_id === inventoryId) {
                    appendMessage(incomingMessage.content, false, incomingMessage.created_at);
                }
            });

            socket.on('chat:error', (errorData) => {
                alert(`Error en el chat: ${errorData.message}`);
            });
        });
    </script>
</body>
</html>