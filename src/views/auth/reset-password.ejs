<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Restablece tu contraseña de Ecommerce de forma segura." />
    <title><%= title %> — Ecommerce</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/auth.css" />
  </head>
  <body>
    <div class="auth-background">
      <div class="auth-orb auth-orb--1"></div>
      <div class="auth-orb auth-orb--2"></div>
      <div class="auth-orb auth-orb--3"></div>
    </div>

    <main class="auth-container" id="auth-main">
      <div class="auth-card animate-fade-in">
        <div class="auth-header">
          <div class="auth-logo">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="12" fill="url(#logo-gradient)" />
              <path d="M12 16L20 12L28 16V24L20 28L12 24V16Z" stroke="white" stroke-width="1.5" fill="none" />
              <path d="M20 12V28" stroke="white" stroke-width="1.5" opacity="0.5" />
              <path d="M12 16L28 24" stroke="white" stroke-width="1.5" opacity="0.3" />
              <path d="M28 16L12 24" stroke="white" stroke-width="1.5" opacity="0.3" />
              <defs>
                <linearGradient id="logo-gradient" x1="0" y1="0" x2="40" y2="40">
                  <stop stop-color="#6366f1" />
                  <stop offset="1" stop-color="#8b5cf6" />
                </linearGradient>
              </defs>
            </svg>
          </div>
          <h1 class="auth-title">Restablecer contraseña</h1>
          <p class="auth-subtitle">
            <% if (step === 'email') { %>
              Ingresa tu correo electrónico para verificar tu cuenta
            <% } else { %>
              Ingresa tu nueva contraseña
            <% } %>
          </p>
        </div>

        <% if (errors && errors.length > 0) { %>
          <div class="auth-alert auth-alert--error animate-shake" id="reset-errors">
            <svg class="auth-alert__icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <ul class="auth-alert__list">
              <% errors.forEach(function(err) { %>
                <li><%= err %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="auth-alert auth-alert--success animate-fade-in" id="reset-success">
            <svg class="auth-alert__icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <p><%= success %></p>
          </div>
        <% } %>

        <% if (step === 'email' && !success) { %>
          <form class="auth-form" method="POST" action="/auth/reset-password/verify" id="reset-email-form" novalidate>
            <div class="auth-field">
              <label class="auth-label" for="reset-email">Correo electrónico</label>
              <div class="auth-input-wrapper">
                <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                </svg>
                <input
                  class="auth-input"
                  type="email"
                  id="reset-email"
                  name="email"
                  placeholder="tu@correo.com"
                  value="<%= email || '' %>"
                  autocomplete="email"
                  required
                />
              </div>
            </div>

            <button type="submit" class="auth-btn" id="reset-verify-btn">
              <span class="auth-btn__text">Verificar correo</span>
              <svg class="auth-btn__arrow" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </form>
        <% } %>

        <% if (step === 'password') { %>
          <form class="auth-form" method="POST" action="/auth/reset-password" id="reset-password-form" novalidate>
            <input type="hidden" name="email" value="<%= email %>" />

            <div class="auth-field">
              <label class="auth-label" for="reset-new-password">Nueva contraseña</label>
              <div class="auth-input-wrapper">
                <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                </svg>
                <input
                  class="auth-input"
                  type="password"
                  id="reset-new-password"
                  name="newPassword"
                  placeholder="Mínimo 8 caracteres"
                  autocomplete="new-password"
                  required
                />
                <button type="button" class="auth-toggle-password" data-target="reset-new-password" aria-label="Mostrar contraseña">
                  <svg class="eye-open" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                  </svg>
                  <svg class="eye-closed" width="18" height="18" viewBox="0 0 20 20" fill="currentColor" style="display:none">
                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                  </svg>
                </button>
              </div>
              <div class="password-strength" id="password-strength">
                <div class="password-strength__bar">
                  <div class="password-strength__fill" id="password-strength-fill"></div>
                </div>
                <span class="password-strength__text" id="password-strength-text"></span>
              </div>
            </div>

            <div class="auth-field">
              <label class="auth-label" for="reset-confirm-password">Confirmar nueva contraseña</label>
              <div class="auth-input-wrapper">
                <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                </svg>
                <input
                  class="auth-input"
                  type="password"
                  id="reset-confirm-password"
                  name="confirmNewPassword"
                  placeholder="Repite tu nueva contraseña"
                  autocomplete="new-password"
                  required
                />
                <button type="button" class="auth-toggle-password" data-target="reset-confirm-password" aria-label="Mostrar contraseña">
                  <svg class="eye-open" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                  </svg>
                  <svg class="eye-closed" width="18" height="18" viewBox="0 0 20 20" fill="currentColor" style="display:none">
                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                  </svg>
                </button>
              </div>
            </div>

            <button type="submit" class="auth-btn" id="reset-submit-btn">
              <span class="auth-btn__text">Restablecer Contraseña</span>
              <svg class="auth-btn__arrow" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </form>
        <% } %>

        <div class="auth-footer">
          <p><a href="/auth/signin" class="auth-link auth-link--accent" id="reset-signin-link">← Volver a Iniciar Sesión</a></p>
        </div>
      </div>
    </main>

    <script src="/js/auth.js"></script>
  </body>
</html>
