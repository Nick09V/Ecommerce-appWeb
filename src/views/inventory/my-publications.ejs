<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css"> 
    <style>
        .grid-container { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; }
        .card { border: 1px solid #ccc; padding: 15px; border-radius: 8px; width: 300px; border-left: 4px solid #007bff; }
        .card img { max-width: 100%; height: auto; border-radius: 4px; }
        .badge { background-color: #007bff; color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.8em; }
        .actions { margin-top: 15px; display: flex; gap: 10px; }
    </style>
</head>
<body>
    <header style="display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; background-color: #e9ecef;">
        <h1>Gestión de mi Inventario</h1>
        <nav>
            <a href="/inventory/create" style="margin-right: 15px;">+ Publicar Repuesto</a>
            <a href="/inventory" style="margin-right: 15px; font-weight: bold; color: #28a745;">Ir al Catálogo General</a>
            <form action="/auth/signout" method="POST" style="display: inline;">
                <button type="submit">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 20px;">
        <% if (successMessage) { %>
    <div style="background-color: #d4edda; color: #155724; padding: 15px; border: 1px solid #c3e6cb; border-radius: 4px; margin-bottom: 20px;">
         <%= successMessage %>
    </div>
        <% } %>
        <h2>Mis Componentes Publicados</h2>

        <form action="/inventory/my-publications" method="GET" style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
            <input type="text" name="search" placeholder="Buscar en mis placas..." value="<%= search %>" style="padding: 8px; width: 300px;">
            
            <select name="sortBy" style="padding: 8px;">
                <option value="date_desc" <%= sortBy === 'date_desc' ? 'selected' : '' %>>Más recientes</option>
                <option value="price_asc" <%= sortBy === 'price_asc' ? 'selected' : '' %>>Menor precio</option>
                <option value="price_desc" <%= sortBy === 'price_desc' ? 'selected' : '' %>>Mayor precio</option>
            </select>

            <button type="submit" style="padding: 8px;">Filtrar mi stock</button>
            <a href="/inventory/my-publications">Limpiar</a>
        </form>

        <div class="grid-container">
            <% if (items.length === 0) { %>
                <p>Aún no has publicado ningún componente. ¡Anímate a subir tu primer repuesto!</p>
            <% } else { %>
                <% items.forEach(item => { %>
                    <div class="card">
                        <img src="<%= item.image_url || 'https://via.placeholder.com/300?text=Sin+Imagen' %>" alt="<%= item.title %>">
                        
                        <h3><%= item.title %></h3>
                        <p><strong>N° Parte:</strong> <%= item.part_number %></p>
                        <p><strong>Chasis:</strong> <%= item.chassis_model %></p>
                        <h2 style="color: #007bff;">$<%= item.price %></h2>
                        
                        <span class="badge">Tu publicación</span>
                        <div class="actions">
                            <a href="/inventory/<%= item.id %>/edit"><button>Editar</button></a>
                            <form action="/inventory/<%= item.id %>/delete" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar esta placa definitivamente?');">
                                <button type="submit" style="color: red;">Eliminar</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>
</body>
</html>