<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/styles.css"> 
</head>
<body>
    <div class="bg-orbs">
        <div class="orb orb--1"></div>
        <div class="orb orb--2"></div>
        <div class="orb orb--3"></div>
    </div>

    <header>
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory/create">+ Publicar Repuesto</a>
            <a href="/inventory">Catálogo General</a>
            <a href="/inventory/my-publications">Mis Publicaciones</a>
            <form action="/auth/signout" method="POST" style="display: inline; margin: 0;">
                <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem;">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 2rem; position: relative; z-index: 1;">
        
        <div class="form-container glass-panel">
            
            <div class="form-header">
                <h2><%= title %></h2>
                <p style="color: var(--accent); margin-top: 0.5rem; font-size: 0.875rem;">
                    Estás modificando los datos de la placa ID: #<%= item.id %>
                </p>
            </div>

            <% if (errors && errors.length > 0) { %>
                <div class="alert-error">
                    <strong style="display: block; margin-bottom: 0.5rem;">Por favor corrige lo siguiente:</strong>
                    <ul>
                        <% errors.forEach(err => { %>
                            <li><%= err.msg || err %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <form action="/inventory/<%= item.id %>/edit" method="POST">
                
                <div class="form-group">
                    <label for="title">Título de la publicación</label>
                    <input type="text" id="title" name="title" value="<%= old.title || item.title %>" required>
                </div>

                <div class="form-group">
                    <label>Número de Parte (No editable)</label>
                    <input type="text" value="<%= item.part_number %>" readonly>
                    <div class="form-helper">La identidad técnica del repuesto no puede ser modificada.</div>
                </div>

                <div class="form-group">
                    <label for="chassisModel">Modelo del Chasis/Compatibilidad</label>
                    <input type="text" id="chassisModel" name="chassisModel" value="<%= old.chassisModel || item.chassis_model %>" required>
                </div>

                <div class="form-group">
                    <label for="price">Precio ($)</label>
                    <input type="number" step="0.01" min="0.1" id="price" name="price" value="<%= old.price || item.price %>" required>
                </div>

                <div class="form-group">
                    <label for="description">Descripción y notas técnicas</label>
                    <textarea id="description" name="description"><%= old.description || item.description %></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                    <a href="/inventory/detail/<%= item.id %>" class="btn btn-outline">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>