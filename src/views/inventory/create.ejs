<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css"> 
    <style>
        .form-container { 
            max-width: 600px; 
            margin: 20px auto; 
            padding: 20px; 
            border: 1px solid #ccc; 
            border-radius: 8px; 
            background-color: #fff;
        }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
        .form-group input, .form-group textarea { 
            width: 100%; 
            padding: 8px; 
            box-sizing: border-box; 
            border: 1px solid #ccc; 
            border-radius: 4px;
        }
        .error-box { 
            background-color: #f8d7da; 
            color: #721c24; 
            padding: 10px; 
            border-radius: 4px; 
            margin-bottom: 20px; 
            border: 1px solid #f5c6cb;
        }
        .error-box ul { margin: 0; padding-left: 20px; }
        .btn-submit {
            background-color: #28a745; 
            color: white; 
            padding: 10px 15px; 
            border: none; 
            border-radius: 4px; 
            cursor: pointer;
            font-size: 1em;
        }
        .btn-submit:hover { background-color: #218838; }
    </style>
</head>
<body>
    <header style="display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; background-color: #f8f9fa;">
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory" style="margin-right: 15px;">Catálogo General</a>
            <a href="/inventory/my-publications" style="margin-right: 15px;">Mis Publicaciones</a>
            <form action="/auth/signout" method="POST" style="display: inline;">
                <button type="submit">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 20px;">
        <div class="form-container">
            <h2><%= title %></h2>

            <% if (errors && errors.length > 0) { %>
                <div class="error-box">
                    <ul>
                        <% errors.forEach(err => { %>
                            <li><%= err.msg || err %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <form action="/inventory/create" method="POST" enctype="multipart/form-data" onsubmit="return confirm('¿Estás seguro de que los datos son correctos y deseas publicar este repuesto?');">
                
                <div class="form-group">
                    <label for="title">Título de la publicación *</label>
                    <input type="text" id="title" name="title" value="<%= old.title || '' %>" placeholder="Ej: Fuente de Poder Samsung 55''..." required>
                </div>

                <div class="form-group">
                    <label for="partNumber">Número de Parte *</label>
                    <input type="text" id="partNumber" name="partNumber" value="<%= old.partNumber || '' %>" placeholder="Ej: BN44-00932A" required>
                </div>

                <div class="form-group">
                    <label for="chassisModel">Modelo del Chasis/Compatibilidad *</label>
                    <input type="text" id="chassisModel" name="chassisModel" value="<%= old.chassisModel || '' %>" placeholder="Ej: UN55NU7100" required>
                </div>

                <div class="form-group">
                    <label for="price">Precio estimado ($) *</label>
                    <input type="number" step="0.01" min="0.1" id="price" name="price" value="<%= old.price || '' %>" placeholder="Ej: 45.00" required>
                </div>

                <div class="form-group">
                    <label for="description">Descripción y notas técnicas</label>
                    <textarea id="description" name="description" rows="4" placeholder="Indica el estado del repuesto, si fue probado, fallas conocidas, etc."><%= old.description || '' %></textarea>
                </div>

                <div class="form-group">
                    <label for="image">Fotografía del componente *</label>
                    <input type="file" id="image" name="image" accept="image/*" required>
                    <small style="color: #6c757d;">Selecciona una foto clara del repuesto o de la etiqueta del chasis.</small>
                </div>

                <div style="margin-top: 20px;">
                    <button type="submit" class="btn-submit">Guardar Repuesto</button>
                    <a href="/inventory" style="margin-left: 15px; color: #dc3545; text-decoration: none;">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>