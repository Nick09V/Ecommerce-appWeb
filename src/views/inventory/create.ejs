<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/styles.css"> 
</head>
<body>
    <div class="bg-orbs">
        <div class="orb orb--1"></div>
        <div class="orb orb--2"></div>
        <div class="orb orb--3"></div>
    </div>

    <header>
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory">Catálogo General</a>
            <a href="/inventory/my-publications">Mis Publicaciones</a>
            <form action="/auth/signout" method="POST" style="display: inline; margin: 0;">
                <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem;">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 2rem; position: relative; z-index: 1;">
        
        <div class="form-container glass-panel">
            
            <div class="form-header">
                <h2><%= title %></h2>
            </div>

            <% if (errors && errors.length > 0) { %>
                <div class="alert-error">
                    <ul>
                        <% errors.forEach(err => { %>
                            <li><%= err.msg || err %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <form action="/inventory/create" method="POST" enctype="multipart/form-data" onsubmit="return confirm('¿Estás seguro de que los datos son correctos y deseas publicar este repuesto?');">
                
                <div class="form-group">
                    <label for="title">Título de la publicación *</label>
                    <input type="text" id="title" name="title" value="<%= old.title || '' %>" placeholder="Ej: Fuente de Poder Samsung 55''..." required>
                </div>

                <div class="form-group">
                    <label for="partNumber">Número de Parte *</label>
                    <input type="text" id="partNumber" name="partNumber" value="<%= old.partNumber || '' %>" placeholder="Ej: BN44-00932A" required>
                </div>

                <div class="form-group">
                    <label for="chassisModel">Modelo del Chasis/Compatibilidad *</label>
                    <input type="text" id="chassisModel" name="chassisModel" value="<%= old.chassisModel || '' %>" placeholder="Ej: UN55NU7100" required>
                </div>

                <div class="form-group">
                    <label for="price">Precio estimado ($) *</label>
                    <input type="number" step="0.01" min="0.1" id="price" name="price" value="<%= old.price || '' %>" placeholder="Ej: 45.00" required>
                </div>

                <div class="form-group">
                    <label for="description">Descripción y notas técnicas</label>
                    <textarea id="description" name="description" placeholder="Indica el estado del repuesto, si fue probado, fallas conocidas, etc."><%= old.description || '' %></textarea>
                </div>

                <div class="form-group">
                    <label for="image">Fotografía del componente *</label>
                    <input type="file" id="image" name="image" accept="image/*" required>
                    <div class="form-helper">Selecciona una foto clara del repuesto o de la etiqueta del chasis.</div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn">Guardar Repuesto</button>
                    <a href="/inventory" class="btn btn-outline">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>