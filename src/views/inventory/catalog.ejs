<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Catálogo</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/styles.css"> 
</head>
<body>
    <div class="bg-orbs">
        <div class="orb orb--1"></div>
        <div class="orb orb--2"></div>
        <div class="orb orb--3"></div>
    </div>

    <header>
        <h1>Catálogo de Repuestos</h1>
        <nav>
            <a href="/inventory/create">+ Publicar</a>
            <a href="/inventory/my-publications">Mis Publicaciones</a>
            <a href="/chat" style="color: var(--accent); display: flex; align-items: center; gap: 0.5rem;">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Mensajes
            </a>
            <form action="/auth/signout" method="POST" style="display: inline; margin: 0;">
                <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem;">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 2rem; max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
        
        <form class="search-bar glass-panel" action="/inventory" method="GET">
            <input type="text" name="search" placeholder="Buscar por chasis, # parte..." value="<%= search %>">
            
            <select name="sortBy">
                <option value="date_desc" <%= sortBy === 'date_desc' ? 'selected' : '' %>>Más recientes</option>
                <option value="price_asc" <%= sortBy === 'price_asc' ? 'selected' : '' %>>Menor precio</option>
                <option value="price_desc" <%= sortBy === 'price_desc' ? 'selected' : '' %>>Mayor precio</option>
            </select>

            <button type="submit" class="btn">Buscar</button>
            <a href="/inventory" class="btn btn-outline">Limpiar</a>
        </form>

        <div class="grid-container">
            <% if (items.length === 0) { %>
                <div class="glass-panel" style="grid-column: 1 / -1; text-align: center; padding: 3rem; border-radius: var(--radius);">
                    <p style="color: var(--text-muted);">No se encontraron repuestos disponibles en este momento.</p>
                </div>
            <% } else { %>
                <% items.forEach(item => { %>
                    <div class="card glass-panel">
                        <img src="<%= item.image_url || 'https://via.placeholder.com/300/1e1b4b/4f46e5?text=Sin+Imagen' %>" alt="<%= item.title %>">
                        
                        <div class="card-content">
                            <span class="badge">De otro técnico</span>
                            <h3 class="card-title"><%= item.title %></h3>
                            
                            <div class="card-specs">
                                <div><strong>N° Parte:</strong> <%= item.part_number %></div>
                                <div><strong>Chasis:</strong> <%= item.chassis_model %></div>
                            </div>
                            
                            <div class="card-price">$<%= item.price %></div>
                            
                            <div class="actions">
                                <a href="/inventory/detail/<%= item.id %>" class="btn">Ver Detalles</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>
</body>
</html>