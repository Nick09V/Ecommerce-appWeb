<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/styles.css"> 
</head>
<body>
    <div class="bg-orbs">
        <div class="orb orb--1"></div>
        <div class="orb orb--2"></div>
        <div class="orb orb--3"></div>
    </div>

    <header>
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory/create">+ Publicar Repuesto</a>
            <a href="/inventory">Catálogo General</a>
            <a href="/inventory/my-publications">Mis Publicaciones</a>
            <a href="/chat" style="color: var(--accent); display: flex; align-items: center; gap: 0.5rem;">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Mensajes
            </a>
            <form action="/auth/signout" method="POST" style="display: inline; margin: 0;">
                <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem;">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 2rem; position: relative; z-index: 1;">
        
        <div class="detail-wrapper">
            
            <% if (successMessage) { %>
                <div class="alert-success glass-panel">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= successMessage %>
                </div>
            <% } %>

            <a href="/inventory" class="back-link">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Volver al catálogo
            </a>

            <div class="detail-grid">
                
                <div class="detail-image-wrapper glass-panel">
                    <img src="<%= item.image_url || 'https://via.placeholder.com/600/1e1b4b/4f46e5?text=Sin+Imagen' %>" alt="<%= item.title %>">
                </div>
                
                <div class="detail-info">
                    <div>
                        <h2 class="detail-title"><%= item.title %></h2>
                        <div class="detail-date">Publicado el: <%= new Date(item.created_at).toLocaleDateString('es-ES') %></div>
                    </div>

                    <div class="detail-price">$<%= item.price %></div>
                    
                    <div class="spec-group">
                        <div class="spec-label">N° de Parte (Part Number)</div>
                        <div class="spec-value"><%= item.part_number %></div>
                    </div>
                    
                    <div class="spec-group">
                        <div class="spec-label">Compatibilidad / Modelo de Chasis</div>
                        <div class="spec-value"><%= item.chassis_model %></div>
                    </div>

                    <div style="margin-top: auto;">
                        <% if (currentUserId === item.user_id) { %>
                            
                            <div class="owner-actions">
                                <strong>Gestionar tu publicación</strong>
                                <div class="btn-group">
                                    <a href="/inventory/<%= item.id %>/edit" class="btn btn-warning">Editar</a>
                                    
                                    <form action="/inventory/<%= item.id %>/delete" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar esta placa? Esta acción no se puede deshacer.');" style="margin: 0;">
                                        <button type="submit" class="btn btn-danger">Eliminar</button>
                                    </form>
                                </div>
                            </div>

                        <% } else { %>
                            
                            <a href="/chat/<%= item.id %>" class="btn" style="width: 100%; justify-content: center; font-size: 1.125rem; padding: 1rem;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right: 0.5rem;">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                </svg>
                                Contactar Vendedor
                            </a>

                        <% } %>
                    </div>
                </div>
            </div>

            <% if (item.description) { %>
                <div class="description-box glass-panel">
                    <strong style="color: var(--text-main); display: block; margin-bottom: 0.5rem; font-size: 1.125rem;">Notas Técnicas y Descripción:</strong>
                    <%= item.description %>
                </div>
            <% } %>

        </div>
    </main>
</body>
</html>