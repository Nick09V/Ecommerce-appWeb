<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css"> 
    <style>
        .detail-container { 
            max-width: 800px; 
            margin: 20px auto; 
            padding: 20px; 
            border: 1px solid #ccc; 
            border-radius: 8px; 
            background-color: #fff;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        .detail-header {
            border-bottom: 2px solid #f8f9fa;
            padding-bottom: 10px;
        }
        .detail-content {
            display: flex;
            gap: 20px;
        }
        .detail-image {
            flex: 1;
            max-width: 400px;
        }
        .detail-image img {
            width: 100%;
            height: auto;
            border-radius: 8px;
            border: 1px solid #eee;
        }
        .detail-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .price-tag {
            font-size: 2em;
            color: #28a745;
            margin: 0;
        }
        .info-row {
            background-color: #f8f9fa;
            padding: 10px;
            border-radius: 4px;
        }
        .description-box {
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 4px;
            border-left: 4px solid #6c757d;
            white-space: pre-wrap; /* Respeta los saltos de línea que puso el técnico */
        }
        .btn-contact {
            background-color: #007bff; 
            color: white; 
            padding: 12px 20px; 
            border: none; 
            border-radius: 4px; 
            cursor: pointer;
            font-size: 1.1em;
            text-align: center;
            text-decoration: none;
            display: block;
        }
        .btn-contact:hover { background-color: #0056b3; }
        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <header style="display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; background-color: #f8f9fa;">
        <h1>Marketplace de Técnicos</h1>
        <nav>
            <a href="/inventory/create" style="margin-right: 15px;">+ Publicar Repuesto</a>
            <a href="/inventory" style="margin-right: 15px;">Catálogo General</a>
            <a href="/inventory/my-publications" style="margin-right: 15px;">Mis Publicaciones</a>
           <a href="/chat" style="margin-right: 15px; font-weight: bold; color: #007bff;">💬 Mensajes</a>
            <form action="/auth/signout" method="POST" style="display: inline;">
                <button type="submit">Cerrar Sesión</button>
            </form>
        </nav>
    </header>

    <main style="padding: 20px;">
        <% if (successMessage) { %>
    <div style="background-color: #d4edda; color: #155724; padding: 15px; border: 1px solid #c3e6cb; border-radius: 4px; margin-bottom: 20px;">
         <%= successMessage %>
    </div>
<% } %>
        <div class="detail-container">
            <div class="detail-header">
                <a href="/inventory" style="color: #6c757d; text-decoration: none;">&larr; Volver al catálogo</a>
                <h2 style="margin-top: 15px; margin-bottom: 5px;"><%= item.title %></h2>
                <small style="color: #6c757d;">Publicado el: <%= new Date(item.created_at).toLocaleDateString('es-ES') %></small>
            </div>

            <div class="detail-content">
                <div class="detail-image">
                    <img src="<%= item.image_url || 'https://via.placeholder.com/600?text=Sin+Imagen' %>" alt="<%= item.title %>">
                </div>
                
                <div class="detail-info">
                    <h3 class="price-tag">$<%= item.price %></h3>
                    
                    <div class="info-row">
                        <strong>N° de Parte (Part Number):</strong><br>
                        <%= item.part_number %>
                    </div>
                    
                    <div class="info-row">
                        <strong>Compatibilidad / Modelo de Chasis:</strong><br>
                        <%= item.chassis_model %>
                    </div>

                    <div style="margin-top: auto;">
                        <% if (currentUserId === item.user_id) { %>
                            <div style="background-color: #e9ecef; padding: 15px; border-radius: 4px; text-align: center;">
                                <strong>Esta es tu publicación</strong>
                                <div class="action-buttons" style="justify-content: center; margin-top: 15px;">
                                    <a href="/inventory/<%= item.id %>/edit" style="background-color: #ffc107; color: black; padding: 8px 15px; text-decoration: none; border-radius: 4px;">Editar Detalles</a>
                                    <form action="/inventory/<%= item.id %>/delete" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar esta placa?');" style="margin: 0;">
                                        <button type="submit" style="background-color: #dc3545; color: white; border: none; padding: 8px 15px; border-radius: 4px; cursor: pointer;">Eliminar Publicación</button>
                                    </form>
                                </div>
                            </div>
                        <% } else { %>
                            <a href="/chat/<%= item.id %>" class="btn-contact">💬 Contactar Vendedor</a>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (item.description) { %>
                <div style="margin-top: 20px;">
                    <h3>Notas Técnicas y Descripción:</h3>
                    <div class="description-box">
                        <%= item.description %>
                    </div>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>